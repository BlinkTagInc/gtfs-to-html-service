{
  "name": "gtfs-to-html-service",
  "version": "1.3.2",
  "private": true,
  "author": "Brendan Nee <brendan@blinktag.com>",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prepare": "husky",
    "postinstall": "node ./node_modules/gtfs-to-html/scripts/postinstall.js && rm -rf ./views && cp -r ./node_modules/gtfs-to-html/views/default ./views"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@vercel/analytics": "^2.0.1",
    "gtfs-to-html": "^2.12.8",
    "next": "^16.2.4",
    "react": "^19",
    "react-dom": "^19",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.73.1",
    "react-toastify": "^11.1.0",
    "tempy": "^3.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.3",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^10",
    "eslint-config-next": "^16.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.3",
    "typescript": "^6"
  },
  "release-it": {
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/keep-a-changelog": {
        "filename": "CHANGELOG.md"
      }
    },
    "hooks": {
      "after:bump": "npm run build"
    }
  },
  "prettier": {
    "singleQuote": true
  },
  "lint-staged": {
    "*.js": "prettier --write",
    "*.jsx": "prettier --write",
    "*.ts": "prettier --write",
    "*.tsx": "prettier --write",
    "*.json": "prettier --write"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "gtfs-to-html",
      "puppeteer"
    ]
  }
}
